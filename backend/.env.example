MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=riskhub

# AES-256-GCM master key for exchange credential envelopes:
#   enc::<base64_iv>::<base64_tag>::<base64_ciphertext>
#
# Supported formats:
# - raw 32-byte string
# - 64-char hex string
# - base64 / urlsafe-base64 encoded 32-byte key
# - any other passphrase-style string (expanded via SHA-256)
RISKHUB_ENCRYPTION_KEY=replace-this-with-your-real-key
